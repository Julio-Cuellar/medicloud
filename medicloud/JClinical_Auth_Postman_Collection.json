		{
			"name": "05 · Staff — Invitación y Aceptación",
			"item": [
				{
					"name": "14. POST /staff/invite — Doctor con cédula",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var j = pm.response.json();",
									"console.log('Buscar invitation_token en los logs del servidor');",
									"console.log(JSON.stringify(j, null, 2));"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
						},
						"method": "POST",
						"header": [
							{ "key": "X-Clinic-ID", "value": "{{clinic_id}}", "type": "text" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"dra.perez@clinica.com\",\n  \"full_name\": \"Dra. Ana Pérez\",\n  \"role\": \"doctor\",\n  \"doctor_credentials\": {\n    \"universidad_egreso\": \"UNAM\",\n    \"anio_egreso\": 2015,\n    \"especialidad\": \"Medicina General\",\n    \"cedula_profesional\": \"12345678\"\n  }\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{base_url}}/v1/staff/invite",
							"host": ["{{base_url}}"],
							"path": ["v1", "staff", "invite"]
						},
						"description": "Requiere header X-Clinic-ID. Guarda el invitation_token del log para el paso 16."
					},
					"response": []
				},
				{
					"name": "14b. POST /staff/invite — Doctor SIN credenciales (esperado 422)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
						},
						"method": "POST",
						"header": [
							{ "key": "X-Clinic-ID", "value": "{{clinic_id}}", "type": "text" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"doctor.sin.credenciales@clinica.com\",\n  \"full_name\": \"Doctor Sin Credenciales\",\n  \"role\": \"doctor\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{base_url}}/v1/staff/invite",
							"host": ["{{base_url}}"],
							"path": ["v1", "staff", "invite"]
						},
						"description": "Debe devolver 422 con error.code = DOCTOR_CREDENTIAL_REQUIRED."
					},
					"response": []
				},
				{
					"name": "14c. POST /staff/invite — Recepcionista (sin credenciales)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
						},
						"method": "POST",
						"header": [
							{ "key": "X-Clinic-ID", "value": "{{clinic_id}}", "type": "text" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"recepcion@clinica.com\",\n  \"full_name\": \"María Recepción\",\n  \"role\": \"receptionist\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{base_url}}/v1/staff/invite",
							"host": ["{{base_url}}"],
							"path": ["v1", "staff", "invite"]
						},
						"description": "Roles no-doctor no requieren doctor_credentials."
					},
					"response": []
				},
				{
					"name": "15. POST /auth/accept-invitation — Escenario A (usuario nuevo)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var j = pm.response.json();",
									"if (j.data && j.data.access_token) {",
									"    pm.globals.set('staff_access_token', j.data.access_token);",
									"    if (j.data.user && j.data.user.clinics && j.data.user.clinics.length > 0) {",
									"        pm.globals.set('staff_id', j.data.user.clinics[0].staff_id);",
									"    }",
									"    console.log('staff_access_token guardado');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"invitation_token\": \"PEGAR_TOKEN_DEL_LOG\",\n  \"password\": \"ContraseñaDoctor2025!\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{base_url}}/v1/auth/accept-invitation",
							"host": ["{{base_url}}"],
							"path": ["v1", "auth", "accept-invitation"]
						},
						"description": "Email del token no existe en el sistema: crea usuario con la contraseña proporcionada."
					},
					"response": []
				},
				{
					"name": "15b. POST /auth/accept-invitation — Escenario B (usuario existente)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"invitation_token\": \"PEGAR_TOKEN_DEL_LOG_RECEPCIONISTA\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{base_url}}/v1/auth/accept-invitation",
							"host": ["{{base_url}}"],
							"path": ["v1", "auth", "accept-invitation"]
						},
						"description": "Email del token ya existe: solo se vincula la clínica. Sin campo password."
					},
					"response": []
				},
				{
					"name": "15c. POST /auth/accept-invitation — token inválido (esperado 401)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"invitation_token\": \"token-que-no-existe\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{base_url}}/v1/auth/accept-invitation",
							"host": ["{{base_url}}"],
							"path": ["v1", "auth", "accept-invitation"]
						},
						"description": "Debe devolver 401 con error.code = INVITATION_TOKEN_INVALID."
					},
					"response": []
				}
			]
		},
		{
			"name": "06 · Staff — Perfil y Credenciales",
			"item": [
				{
					"name": "16. GET /staff/{id} — Doctor (con doctor_credentials)",
					"event": [
						{
							"listen": "test",
