						"auth": {
							"type": "bearer",
							"bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
						},
						"method": "GET",
						"header": [
							{ "key": "X-Clinic-ID", "value": "{{clinic_id}}", "type": "text" }
						],
						"url": {
							"raw": "{{base_url}}/v1/staff/{{staff_id}}",
