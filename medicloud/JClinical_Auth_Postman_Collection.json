					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
						},
						"method": "PATCH",
						"header": [
							{ "key": "X-Clinic-ID", "value": "{{clinic_id}}", "type": "text" }
						],
						"url": {
							"raw": "{{base_url}}/v1/staff/{{staff_id}}/credentials/verify",
							"host": ["{{base_url}}"],
							"path": ["v1", "staff", "{{staff_id}}", "credentials", "verify"]
						},
						"description": "Marca las credenciales como verificadas. Responde con credential_status y verified_at."
					},
					"response": []
				},
				{
					"name": "17b. PATCH credentials/verify — no es doctor (esperado 422)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
						},
						"method": "PATCH",
						"header": [
							{ "key": "X-Clinic-ID", "value": "{{clinic_id}}", "type": "text" }
						],
						"url": {
							"raw": "{{base_url}}/v1/staff/{{receptionist_staff_id}}/credentials/verify",
							"host": ["{{base_url}}"],
							"path": ["v1", "staff", "{{receptionist_staff_id}}", "credentials", "verify"]
						},
						"description": "Usar el staff_id de la recepcionista. Debe devolver 422 STAFF_NOT_A_DOCTOR."
					},
					"response": []
				},
				{
					"name": "17c. GET /staff/{id} — después de verificar (credential_status actualizado)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
						},
						"method": "GET",
						"header": [
							{ "key": "X-Clinic-ID", "value": "{{clinic_id}}", "type": "text" }
						],
						"url": {
							"raw": "{{base_url}}/v1/staff/{{staff_id}}",
							"host": ["{{base_url}}"],
							"path": ["v1", "staff", "{{staff_id}}"]
						},
						"description": "Verificar que verified_at esté poblado y credential_status sea 'activo'."
					},
					"response": []
				}
			]
		},
		{
			"name": "07 · Errores — Validaciones de Contrato",
			"item": [
				{
					"name": "E1. Error genérico — campo request_id en snake_case",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"token\": \"token-inexistente\"\n}",
							"options": { "raw": { "language": "json" } }
