					"script": {
						"exec": [
							"pm.test(\"Status code es 200 (OK)\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Retorna mensaje de éxito\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.message).to.eql(\"Correo verificado exitosamente y cuenta activada\");",
