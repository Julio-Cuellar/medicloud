	"item": [
		{
			"name": "1. Registrar Usuario",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code es 200 o 201 (Creado)\", function () {",
							"    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
							"});",
							"",
							"pm.test(\"Retorna estructura de pre-registro inactivo\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property(\"id\");",
							"    pm.expect(jsonData.email).to.eql(\"doctor.jcuellar@gmail.com\");",
							"    pm.expect(jsonData.emailVerified).to.be.false;",
							"    pm.expect(jsonData.active).to.be.false;",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"email\": \"doctor.jcuellar@gmail.com\",\n  \"password\": \"SecurePassword123*\",\n  \"fullName\": \"Dr. Julio Cuellar\",\n  \"clinicName\": \"JClinical Medicloud\"\n}"
				},
				"url": {
					"raw": "http://localhost:8082/api/v1/users/register",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8082",
					"path": [
						"api",
						"v1",
						"users",
						"register"
					]
				},
				"description": "Endpoint para realizar el pre-registro temporal del representante legal. Guarda los datos temporalmente por 15 minutos."
			},
			"response": []
		},
		{
