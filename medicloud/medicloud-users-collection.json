		{
			"name": "3. Iniciar Sesión (Login JWT)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code es 200 (OK)\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Retorna token JWT y datos de usuario\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property(\"token\");",
							"    pm.expect(jsonData.tokenType).to.eql(\"Bearer\");",
							"    pm.expect(jsonData.user.email).to.eql(\"doctor.jcuellar@gmail.com\");",
							"    pm.expect(jsonData.user.active).to.be.true;",
							"",
							"    // Guardar token automáticamente para la petición GET /me",
							"    pm.collectionVariables.set(\"jwt_token\", jsonData.token);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"email\": \"doctor.jcuellar@gmail.com\",\n  \"password\": \"SecurePassword123*\"\n}"
				},
				"url": {
					"raw": "http://localhost:8082/api/v1/auth/login",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8082",
					"path": [
						"api",
						"v1",
						"auth",
						"login"
					]
				},
				"description": "Autentica al usuario activo y devuelve el token JWT."
			},
			"response": []
		},
		{
			"name": "4. Obtener Perfil (GET /auth/me)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code es 200 (OK)\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Retorna perfil de usuario con sus consultorios\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property(\"id\");",
							"    pm.expect(jsonData.email).to.eql(\"doctor.jcuellar@gmail.com\");",
							"    pm.expect(jsonData.clinics).to.be.an(\"array\");",
							"    pm.expect(jsonData.clinics[0].name).to.eql(\"JClinical Medicloud\");",
							"",
							"    // Guardar el ID de la clínica original para actualizarla",
							"    if (jsonData.clinics && jsonData.clinics.length > 0) {",
							"        pm.collectionVariables.set(\"clinic_original_id\", jsonData.clinics[0].id);",
							"    }",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "{{jwt_token}}",
							"type": "string"
						}
					]
				},
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:8082/api/v1/auth/me",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8082",
					"path": [
						"api",
						"v1",
						"auth",
						"me"
